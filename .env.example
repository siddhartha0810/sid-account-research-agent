# ─────────────────────────────────────────────────────────────────────────────
# TrueRestore Account Research Agent — environment variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Shadow mode ──────────────────────────────────────────────────────────────
# When true: Slack/Linear print to stdout, HubSpot/Origami load from mocks/.
# Set to false only in a real environment with valid API keys.
SHADOW_MODE=true

# ── Agent ────────────────────────────────────────────────────────────────────
# Hard cap on Claude tool-loop iterations per run.
MAX_LOOP_ITERATIONS=10

# Override the Claude model (optional — defaults to claude-sonnet-4-6).
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Anthropic ────────────────────────────────────────────────────────────────
# Required. Get yours at console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# ── HubSpot ──────────────────────────────────────────────────────────────────
# Required when SHADOW_MODE=false.
# Private app token (Settings → Integrations → Private Apps).
# Scopes needed: crm.objects.companies.read, crm.objects.companies.write,
#                crm.objects.contacts.read, crm.objects.contacts.write,
#                crm.objects.notes.read, crm.objects.notes.write,
#                crm.associations.read, crm.associations.write
HUBSPOT_API_KEY=pat-na1-...

# ── Origami (origami.chat) ────────────────────────────────────────────────────
# Required when SHADOW_MODE=false.
# API key created in Origami Settings → API Keys. Must start with og_live_
ORIGAMI_API_KEY=og_live_...

# Table ID from your Origami workspace (the company enrichment table).
# Found in the table URL: origami.chat/tables/<TABLE_ID>
ORIGAMI_TABLE_ID=tbl_...

# ── Slack ────────────────────────────────────────────────────────────────────
# Required when SHADOW_MODE=false.
# Bot user OAuth token (xoxb-...). Bot must be added to the target channel.
# Scopes needed: chat:write, channels:read
SLACK_BOT_TOKEN=xoxb-...

# Channel ID (not name) for the #account-research channel.
# Find it by right-clicking the channel in Slack → Copy link — the ID is at the end.
SLACK_CHANNEL_ID=C0...

# ── Linear ───────────────────────────────────────────────────────────────────
# Required when SHADOW_MODE=false.
# Personal API key from Linear Settings → API → Personal API keys. Starts with lin_api_
LINEAR_API_KEY=lin_api_...

# Team ID from Linear Settings → Members → your team row → copy ID.
LINEAR_TEAM_ID=...

# ── Cache ────────────────────────────────────────────────────────────────────
# Path to the local JSON cache file (default: cache.json in the project root).
# CACHE_FILE_PATH=cache.json
